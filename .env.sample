# ── Database ───────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./expense.db
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/hisaab

# ── AI parsing ─────────────────────────────────────────────────────────────
# Used by services.parse_message_with_ai (LiteLLM → Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram bot ───────────────────────────────────────────────────────────
# Get these from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Username WITHOUT @ — shown on the landing page login button
TELEGRAM_BOT_USERNAME=YourBotName
